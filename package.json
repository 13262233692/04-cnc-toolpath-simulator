{
  "name": "cnc-toolpath-simulator",
  "version": "1.0.0",
  "description": "五轴数控机床仿真监控上位机 - Electron + Vue3 + Rust Node-API",
  "main": "electron/main.js",
  "author": "CNC Simulator Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build:rust": "cd rust-core && napi build --platform --release",
    "build:vite": "vite build",
    "build": "npm run build:rust && npm run build:vite && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "three": "^0.160.0",
    "@napi-rs/canvas": "^0.1.44"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3",
    "@napi-rs/cli": "^2.16.3"
  },
  "napi": {
    "name": "cnc-native",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "build": {
    "appId": "com.cnc.simulator",
    "productName": "CNC Toolpath Simulator",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "rust-native/*.node"
    ],
    "directories": {
      "output": "release"
    }
  }
}
