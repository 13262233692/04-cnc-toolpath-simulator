%
O0001 (FIVE-AXIS DEMO PROGRAM - IMPELLER STYLE)
G90 G94 G17 G40 G49 G80
G21 (MM UNITS)
G54 (WORK COORDINATE SYSTEM)
T1 M6 (BALL NOSE END MILL D10)
S12000 M03
G43 H1 Z300.0
M08

(--- ROUGHING PASSES ---)
G00 A0.0 B0.0
G00 X0.0 Y0.0 Z50.0

(START HELICAL PLUNGE)
#1 = 0.0
#2 = 100.0
#3 = 15.0
#4 = 30.0
#5 = 0.0
#6 = 360.0
#7 = 0.5
#8 = 2.0

G01 F1500 Z40.0

WHILE [#1 LT 50.0] DO1
  #1 = #1 + #7
  #9 = 0.0
  WHILE [#9 LE #6] DO2
    #9 = #9 + #8
    #10 = #3 * COS[#9]
    #11 = #4 * SIN[#9]
    #12 = 20.0 * SIN[#1 * 3.0]
    #13 = 15.0 * COS[#9 * 0.5 + #1 * 2.0]
    G01 X#10 Y#11 Z[#2 - #1] A#12 B#13 F2500
  END2
END1

(--- FINISH PASSES - HIGH DENSITY ---)
G00 X0.0 Y0.0 Z50.0
G01 Z40.0 F3000

#20 = 0.0
WHILE [#20 LT 45.0] DO3
  #20 = #20 + 0.1
  #21 = 0.0
  WHILE [#21 LE 360.0] DO4
    #21 = #21 + 0.5
    #22 = [15.0 + 2.0 * SIN[#20 * 10.0]] * COS[#21]
    #23 = [30.0 + 3.0 * COS[#20 * 8.0]] * SIN[#21]
    #24 = 100.0 - #20
    #25 = 10.0 + 8.0 * SIN[#21 + #20 * 5.0]
    #26 = 12.0 * COS[#20 * 6.0 - #21 * 0.3]
    G01 X#22 Y#23 Z#24 A#25 B#26 F4000
  END4
END3

(--- FIVE AXIS SWEEP ---)
G00 X-80.0 Y-60.0 Z100.0
G01 A-30.0 B-45.0 F2000

#30 = 0.0
WHILE [#30 LE 100.0] DO5
  #30 = #30 + 0.2
  #31 = -80.0 + #30
  #32 = -60.0 + SIN[#30 * 0.3] * 20.0
  #33 = 80.0 - #30 * 0.5 + COS[#30 * 0.2] * 10.0
  #34 = -30.0 + #30 * 0.8
  #35 = -45.0 + SIN[#30 * 0.15] * 20.0
  G01 X#31 Y#32 Z#33 A#34 B#35 F3500
END5

(--- CIRCULAR POCKET PATTERN ---)
G00 X0.0 Y0.0 Z80.0
G01 A15.0 B30.0
G01 Z50.0 F2000

#40 = 0.0
WHILE [#40 LE 1080.0] DO6
  #40 = #40 + 1.0
  #41 = 25.0 * COS[#40]
  #42 = 25.0 * SIN[#40]
  #43 = 50.0 - 20.0 * [#40 / 1080.0]
  #44 = 15.0 + 10.0 * SIN[#40 * 0.7]
  #45 = 30.0 + 15.0 * COS[#40 * 0.5]
  G01 X#41 Y#42 Z#43 A#44 B#45 F3000
END6

(--- FINAL RETRACT ---)
G00 Z300.0
G00 A0.0 B0.0
G00 X0.0 Y0.0
S0 M05
M09
G91 G28 Z0.0
G91 G28 X0.0 Y0.0 A0.0 B0.0
M30
%
